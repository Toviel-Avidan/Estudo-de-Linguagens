CREATE DATABASE IF NOT EXISTS palacio_mental
DEFAULT CHARACTER SET utf8mb4
DEFAULT COLLATE utf8mb4_0900_ai_ci;

USE palacio_mental;

-- 👤 USUÁRIOS
CREATE TABLE usuarios (
    id_usuario INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    email VARCHAR(120) NOT NULL UNIQUE,
    senha VARCHAR(255) NOT NULL,
    criado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 📎 ARQUIVOS EXTERNOS
CREATE TABLE arquivosExternos (
    id_arquivoExterno INT AUTO_INCREMENT PRIMARY KEY,
    nome_arquivo VARCHAR(255) NOT NULL,
    tipo_arquivo VARCHAR(50),
    caminho VARCHAR(255) NOT NULL,
    enviado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 🧸 OBJETOS EXTERNOS (ANOTAÇÕES)
CREATE TABLE objetosExternos (
    id_objetoExterno INT AUTO_INCREMENT PRIMARY KEY,
    id_arquivoExterno INT NOT NULL,
    titulo VARCHAR(120) NOT NULL,
    conteudo TEXT,
    posicao_x INT DEFAULT 0,
    posicao_y INT DEFAULT 0,
    criado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    atualizado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (id_arquivoExterno) REFERENCES arquivosExternos(id_arquivoExterno)
        ON DELETE CASCADE
);

-- 📎 ARQUIVOS INTERNOS
CREATE TABLE arquivosInternos (
    id_arquivoInterno INT AUTO_INCREMENT PRIMARY KEY,
    nome_arquivo VARCHAR(255) NOT NULL,
    tipo_arquivo VARCHAR(50),
    caminho VARCHAR(255) NOT NULL,
    enviado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 🧸 OBJETOS INTERNOS (ANOTAÇÕES)
CREATE TABLE objetosInternos (
    id_objetoInterno INT AUTO_INCREMENT PRIMARY KEY,
    id_arquivoInterno INT NOT NULL,
    titulo VARCHAR(120) NOT NULL,
    conteudo TEXT,
    posicao_x INT DEFAULT 0,
    posicao_y INT DEFAULT 0,
    criado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    atualizado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (id_arquivoInterno) REFERENCES arquivosInternos(id_arquivoInterno)
        ON DELETE CASCADE
);

-- 🚪 QUARTOS
CREATE TABLE quartos (
    id_quarto INT AUTO_INCREMENT PRIMARY KEY,
    id_objetoInterno INT NOT NULL,
    nome VARCHAR(100) NOT NULL,
    descricao VARCHAR(255),
    posicao_x INT DEFAULT 0,
    posicao_y INT DEFAULT 0,
    criado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_objetoInterno) REFERENCES objetosInternos(id_objetoInterno)
        ON DELETE CASCADE
);

-- 🧱 ANDARES
CREATE TABLE andares (
    id_andar INT AUTO_INCREMENT PRIMARY KEY,
    id_quarto INT NOT NULL,
    numero INT NOT NULL,
    descricao VARCHAR(255),
    posicao_x INT DEFAULT 0,
    posicao_y INT DEFAULT 0,
    criado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_quarto) REFERENCES quartos(id_quarto)
        ON DELETE CASCADE
);

-- 🗼 TORRES
CREATE TABLE torres (
    id_torre INT AUTO_INCREMENT PRIMARY KEY,
    id_andar INT NOT NULL,
    id_quarto INT NOT NULL,
    nome VARCHAR(100) NOT NULL,
    descricao VARCHAR(255),
    posicao_x INT DEFAULT 0,
    posicao_y INT DEFAULT 0,
    criado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_andar) REFERENCES andares(id_andar),
    FOREIGN KEY (id_quarto) REFERENCES quartos(id_quarto)
        ON DELETE CASCADE
);

-- 🏢 PALÁCIOS
CREATE TABLE palacios (
    id_palacio INT AUTO_INCREMENT PRIMARY KEY,
    id_torre INT NOT NULL,
    id_andar INT NOT NULL,
    id_quarto INT NOT NULL,
    nome VARCHAR(100) NOT NULL,
    descricao VARCHAR(255),
    posicao_x INT DEFAULT 0,
    posicao_y INT DEFAULT 0,
    criado_em TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_torre) REFERENCES torres(id_torre),
    FOREIGN KEY (id_andar) REFERENCES andares(id_andar),
    FOREIGN KEY (id_quarto) REFERENCES quartos(id_quarto)
        ON DELETE CASCADE
);

